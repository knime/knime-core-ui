{
  "name": "knime-base-views-iframe",
  "version": "0.1.0",
  "description": "Views for KNIME which are embedded as IFrames",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run type-check & vite build",
    "type-check": "tsc -p tsconfig.vitest.json",
    "lint": "run-p 'lint:* -- --fix'",
    "lint:js": "eslint . --cache --ext .js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts",
    "lint:css": "stylelint '**/*.css' --cache",
    "format": "prettier --cache --write .",
    "format:check": "prettier --cache --check .",
    "ci:lint-format": "run-p lint:* format:check -c",
    "ci:audit": "check-audit --omit dev",
    "audit:resolve": "resolve-audit --omit dev",
    "jenkins:lint": "eslint --cache --ext .js,.ts,.json . -f json -o target/eslint.json || true; stylelint '**/*.css' -f json -o target/stylelint.json || true",
    "jenkins:audit": "check-audit --omit dev --json > target/audit.json || true",
    "test": "npm run test:unit",
    "test:unit": "jest --runInBand",
    "coverage": "jest --coverage --runInBand",
    "prepare": "cd ../../.. && husky ./org.knime.core.ui/js-src/data-value-renderers/.husky",
    "sbom": "npx @cyclonedx/cyclonedx-npm --output-file bom.json --ignore-npm-errors --omit dev",
    "postinstall": "license-check -c"
  },
  "license": "UNLICENSED",
  "author": "KNIME AG, Zurich, Switzerland",
  "dependencies": {
    "@knime/styles": "1.0.3",
    "@knime/ui-extension-service": "0.39.0",
    "echarts": "5.4.2",
    "monaco-editor": "^0.51.0",
    "vite-plugin-monaco-editor": "^1.1.0"
  },
  "devDependencies": {
    "@babel/plugin-transform-modules-commonjs": "7.23.3",
    "@babel/preset-env": "7.24.0",
    "@cyclonedx/cyclonedx-npm": "^1.16.1",
    "@knime/eslint-config": "8.1.0",
    "@knime/licenses": "1.0.5",
    "@tsconfig/node20": "20.1.4",
    "@types/echarts": "4.9.22",
    "@types/estree": "1.0.5",
    "@types/jest": "29.5.12",
    "eslint": "8.57.0",
    "flush-promises": "1.0.2",
    "husky": "9.1.4",
    "jest": "29.7.0",
    "jest-environment-jsdom": "29.7.0",
    "jest-junit": "16.0.0",
    "jest-transform-stub": "2.0.0",
    "npm-audit-resolver": "3.0.0-RC.0",
    "npm-run-all": "4.1.5",
    "postcss-import": "16.0.1",
    "postcss-preset-env": "9.5.0",
    "postcss-url": "10.1.3",
    "prettier": "3.2.5",
    "stylelint": "16.2.1",
    "ts-jest": "29.1.2",
    "ts-loader": "9.2.6",
    "typescript": "5.3.3",
    "vite": "5.1.6"
  },
  "engines": {
    "node": "20.x"
  },
  "volta": {
    "node": "20.11.1"
  }
}
